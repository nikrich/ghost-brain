{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "outDir": "out/.tsbuildinfo-web"
  },
  "references": [{ "path": "./tsconfig.shared.json" }],
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
