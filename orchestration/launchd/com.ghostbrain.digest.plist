<?xml version="1.0" encoding="UTF-8"?>
<!--
  Daily digest generation. Runs at 06:30 local time.

  This file is a TEMPLATE. Before loading, replace the two placeholders:
    __REPO_ROOT__   absolute path to your local clone of ghost-brain
    __VAULT_PATH__  absolute path to your vault (default ~/ghostbrain/vault)

  See com.ghostbrain.worker.plist for the sed snippet that does the
  substitution in one pass.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ghostbrain.digest</string>

    <key>ProgramArguments</key>
    <array>
        <string>__REPO_ROOT__/.venv/bin/python</string>
        <string>-m</string>
        <string>ghostbrain.worker.digest</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__</string>

    <key>RunAtLoad</key>
    <false/>

    <!-- Daily at 06:30 local time. SPEC §8.1. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__REPO_ROOT__/logs/digest.log</string>

    <key>StandardErrorPath</key>
    <string>__REPO_ROOT__/logs/digest.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>VAULT_PATH</key>
        <string>__VAULT_PATH__</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
